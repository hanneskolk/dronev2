import os
import cv2
from ultralytics import YOLO
from tqdm import tqdm
import torch

INPUT_DIR = "input_videos"
OUTPUT_DIR = "output_videos"

os.makedirs(OUTPUT_DIR, exist_ok=True)

if(torch.cuda.is_available() == True):
    model = YOLO("/content/dronev2/models/best.engine")
else:
    model = YOLO("/content/dronev2/models/best.pt")
    model.fuse()

def process_video(video_path):
    cap = cv2.VideoCapture(video_path)

    fps = cap.get(cv2.CAP_PROP_FPS)
    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))

    output_path = os.path.join(OUTPUT_DIR, os.path.basename(video_path))

    out = cv2.VideoWriter(
        output_path,
        cv2.VideoWriter_fourcc(*"mp4v"),
        fps,
        (w, h)
    )

    frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))

    for _ in tqdm(range(frame_count), desc=os.path.basename(video_path)):
        ret, frame = cap.read()
        if not ret:
            break

        # 🚀 GPU inference with TensorRT
        if (torch.cuda.is_available() == True):
            results = model.predict(
                source=frame,
                conf=0.15,     # low threshold = fewer missed detections
                device=0,
                verbose=False
            )[0]
        else:
            results = model.predict(
                source=frame,
                conf=0.15,     # low threshold = fewer missed detections
                device="cpu",
                verbose=False
            )[0]

        annotated = results.plot()

        out.write(annotated)

    cap.release()
    out.release()


def main():
    videos = [v for v in os.listdir(INPUT_DIR) if v.endswith(".mp4")]

    for video in videos:
        process_video(os.path.join(INPUT_DIR, video))


if __name__ == "__main__":
    main()